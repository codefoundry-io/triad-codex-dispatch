# Copy this template into ~/.codex/rules/triad-codex-dispatch.rules only when
# you intentionally maintain the rules by hand. Otherwise, run the freshly
# printed absolute `--install` command from an unrelated project working
# directory to generate these rules with user-specific absolute paths.
#
# Before copying manually, replace:
# - /path/to/launcher-dir with your absolute TRIAD_BOOTSTRAP_BIN_DIR
#   (default: /Users/YOUR_USER/.local/bin)
# - /path/to/triad-codex-dispatch with the checkout used by bootstrap
# - /path/to/workspace with the trusted workspace root used for prompt files and --cwd
#
# Agent Review routing requires literal argv whose first token is the absolute
# bootstrap launcher path. Do not add bare wrapper names, checkout bin/*.py
# paths, python3, env, bash -lc, or zsh -lc as broader patterns.
#
# Discover agy model labels live with `agy models`; do not bake a model name
# into a prompt-rule match.
#
# See:
# Expected: matchedRules contains one triad-codex-dispatch prompt rule.
# codex execpolicy check --pretty --rules ~/.codex/rules/triad-codex-dispatch.rules -- /path/to/launcher-dir/claude_wrapper.py --prompt hi --sandbox read-only
# codex execpolicy check --pretty --rules ~/.codex/rules/triad-codex-dispatch.rules -- /path/to/launcher-dir/claude_wrapper.py --prompt-file /path/to/workspace/_runs/prompts/triad-prompt.txt --sandbox read-only
# Expected: matchedRules is empty.
# codex execpolicy check --pretty --rules ~/.codex/rules/triad-codex-dispatch.rules -- claude_wrapper.py --prompt hi --sandbox read-only
# codex execpolicy check --pretty --rules ~/.codex/rules/triad-codex-dispatch.rules -- /path/to/triad-codex-dispatch/bin/claude_wrapper.py --prompt hi --sandbox read-only
# codex execpolicy check --pretty --rules ~/.codex/rules/triad-codex-dispatch.rules -- python3 /path/to/triad-codex-dispatch/bin/gemini_wrapper.py --prompt hi --sandbox read-only
# codex execpolicy check --pretty --rules ~/.codex/rules/triad-codex-dispatch.rules -- zsh -lc "claude_wrapper.py --prompt hi"

prefix_rule(
    pattern = [[
        "/path/to/launcher-dir/claude_wrapper.py",
    ]],
    decision = "prompt",
    justification = "Require approval review; approve only an owner-authorized triad review through the Claude wrapper when the worktree, scope, and named provider match the owner's request and provider-visible input excludes credentials, tokens, cookies, authentication files, environment dumps, provider logs, and unrelated paths. This does not authorize commit, push, install, merge, or release.",
    match = [
        "/path/to/launcher-dir/claude_wrapper.py --prompt hi --sandbox read-only",
        "/path/to/launcher-dir/claude_wrapper.py --prompt-file /path/to/workspace/_runs/prompts/triad-prompt.txt --sandbox read-only",
    ],
    not_match = [
        "claude_wrapper.py --prompt hi --sandbox read-only",
        "/path/to/triad-codex-dispatch/bin/claude_wrapper.py --prompt hi --sandbox read-only",
        "bash -lc claude_wrapper.py --prompt hi",
        "zsh -lc claude_wrapper.py --prompt hi",
        "python3 /path/to/triad-codex-dispatch/bin/claude_wrapper.py --prompt hi --sandbox read-only",
        "/usr/bin/env python3 /path/to/triad-codex-dispatch/bin/claude_wrapper.py --prompt hi --sandbox read-only",
        "python3 -c print('not a triad wrapper')",
    ],
)

prefix_rule(
    pattern = [[
        "/path/to/launcher-dir/antigravity_wrapper.py",
    ]],
    decision = "prompt",
    justification = "Require approval review; approve only an owner-authorized triad review through the Antigravity wrapper when the worktree, scope, and named provider match the owner's request and provider-visible input excludes credentials, tokens, cookies, authentication files, environment dumps, provider logs, and unrelated paths. This does not authorize commit, push, install, merge, or release.",
    match = [
        "/path/to/launcher-dir/antigravity_wrapper.py --prompt hi --sandbox read-only",
        "/path/to/launcher-dir/antigravity_wrapper.py --prompt-file /path/to/workspace/_runs/prompts/triad-prompt.txt --sandbox read-only",
    ],
    not_match = [
        "antigravity_wrapper.py --prompt hi --sandbox read-only",
        "/path/to/triad-codex-dispatch/bin/antigravity_wrapper.py --prompt hi --sandbox read-only",
        "bash -lc antigravity_wrapper.py --prompt hi",
        "zsh -lc antigravity_wrapper.py --prompt hi",
        "python3 /path/to/triad-codex-dispatch/bin/antigravity_wrapper.py --prompt hi --sandbox read-only",
        "/usr/bin/env python3 /path/to/triad-codex-dispatch/bin/antigravity_wrapper.py --prompt hi --sandbox read-only",
        "python3 -c print('not a triad wrapper')",
    ],
)

prefix_rule(
    pattern = [[
        "/path/to/launcher-dir/gemini_wrapper.py",
    ]],
    decision = "prompt",
    justification = "Require approval review; approve only an owner-authorized triad review through the Gemini business-tier wrapper when the worktree, scope, and named provider match the owner's request and provider-visible input excludes credentials, tokens, cookies, authentication files, environment dumps, provider logs, and unrelated paths. This does not authorize commit, push, install, merge, or release.",
    match = [
        "/path/to/launcher-dir/gemini_wrapper.py --prompt hi --sandbox read-only",
        "/path/to/launcher-dir/gemini_wrapper.py --prompt-file /path/to/workspace/_runs/prompts/triad-prompt.txt --sandbox read-only",
    ],
    not_match = [
        "gemini_wrapper.py --prompt hi --sandbox read-only",
        "/path/to/triad-codex-dispatch/bin/gemini_wrapper.py --prompt hi --sandbox read-only",
        "bash -lc gemini_wrapper.py --prompt hi",
        "zsh -lc gemini_wrapper.py --prompt hi",
        "python3 /path/to/triad-codex-dispatch/bin/gemini_wrapper.py --prompt hi --sandbox read-only",
        "/usr/bin/env python3 /path/to/triad-codex-dispatch/bin/gemini_wrapper.py --prompt hi --sandbox read-only",
        "python3 -c print('not a triad wrapper')",
    ],
)
